{
  "mcpServers": {
    "servicenow": {
      "command": "uvx",
      "args": [
        "mfa-servicenow-mcp",
        "--instance-url", "https://your-instance.service-now.com",
        "--auth-type", "browser",
        "--browser-headless", "false"
      ],
      "env": {
        "SERVICENOW_DEBUG": "false",
        "MCP_TOOL_PACKAGE": "standard"
      }
    }
  }
}
