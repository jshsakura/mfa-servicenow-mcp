{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "servicenow": {
      "type": "local",
      "command": [
        "uvx",
        "mfa-servicenow-mcp",
        "--instance-url", "https://your-instance.service-now.com",
        "--auth-type", "browser",
        "--browser-headless", "false"
      ],
      "enabled": true,
      "metadata": {
        "client": "gemini",
        "description": "ServiceNow MCP for Gemini/Vertex AI"
      }
    }
  }
}
