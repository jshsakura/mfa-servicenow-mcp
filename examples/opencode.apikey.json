{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "servicenow": {
      "type": "local",
      "command": [
        "uvx",
        "mfa-servicenow-mcp",
        "--instance-url", "https://your-instance.service-now.com",
        "--auth-type", "api_key",
        "--api-key", "your_api_key"
      ],
      "enabled": true,
      "metadata": {
        "client": "gemini",
        "description": "ServiceNow MCP with API Key"
      }
    }
  }
}
